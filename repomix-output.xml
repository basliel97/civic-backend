  "success": false,
  "error": "Unauthorized: Super Admin only"
}
```

**404 Not Found:**
```json
{
  "success": false,
  "error": "Citizen not found"
}
```

**500 Server Error:**
```json
{
  "success": false,
  "error": "Internal server error"
}
```

